{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ekcelo.ru/contracts/bundle/bundle.schema.json",
  "title": "EKCELO Bundle manifest (C3)",
  "type": "object",
  "required": [
    "bundle_version",
    "contracts_version",
    "kmz_contract_version",
    "kind",
    "objects",
    "files",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "bundle_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "contracts_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "kmz_contract_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "kind": { "type": "string", "enum": ["object", "lot"] },
    "primary_cad_number": { "type": "string" },
    "extract_date": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "etp_layer_present": { "type": "boolean" },
    "generated_by": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "objects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lot": {
      "type": "object",
      "required": ["lot_id", "as_of_date", "members"],
      "additionalProperties": true,
      "properties": {
        "lot_id": { "type": "string", "pattern": "^[A-Za-z0-9_:/-]{1,256}$" },
        "as_of_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "include": { "type": "object" },
        "exclude": { "type": "object" },
        "members": { "type": "array", "items": { "type": "string" } }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "lot" } } },
      "then": { "required": ["lot"] }
    }
  ]
}
