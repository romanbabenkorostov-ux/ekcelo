          "type": "TEXT",
          "nullable": true
        },
        "updated_at": {
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')"
        }
      }
    },
    "object_etp_profile": {
      "section": "6",
      "restorable": false,
      "primary_key": [
        "cad_number"
      ],
      "foreign_keys": [
        {
          "columns": [
            "cad_number"
          ],
          "references": "objects(cad_number)"
        }
      ],
      "columns": {
        "cad_number": {
          "type": "TEXT",
          "nullable": false,
          "pk": true
        },
        "location_extra": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "building_extra": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "layout": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "legal_extra": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "risks": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "extras": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON"
        },
        "source": {
          "type": "TEXT",
          "nullable": false,
          "check_in": [
            "osv",
            "exif",
            "manual",
            "nspd",
            "llm"
          ]
        },
        "confidence": {
          "type": "REAL",
          "nullable": false,
          "check_range": [
            0.0,
            1.0
          ]
        },
        "updated_at": {
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')"
        }
      }
    },
    "lots": {
      "section": "6",
      "restorable": false,
      "primary_key": [
        "lot_id"
      ],
      "foreign_keys": [
        {
          "columns": [
            "primary_cad_number"
          ],
          "references": "objects(cad_number)"
        }
      ],
      "columns": {
        "lot_id": {
          "type": "TEXT",
          "nullable": false,
          "pk": true,
          "note": "pattern [A-Za-z0-9_:/-]{1,256}"
        },
        "name": {
          "type": "TEXT",
          "nullable": false
        },
        "platform_targets": {
          "type": "TEXT",
          "nullable": true,
          "note": "JSON array"
        },
        "procedure_type": {
          "type": "TEXT",
          "nullable": true
        },
        "deal_type": {
          "type": "TEXT",
          "nullable": true,
          "check_in": [
            "sale",
            "lease",
            "other"
          ]
        },
        "primary_cad_number": {
          "type": "TEXT",
          "nullable": true
