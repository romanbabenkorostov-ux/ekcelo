          "nullable": false,
          "note": "CHECK [-90..90]"
        },
        "lon": {
          "type": "REAL",
          "nullable": false,
          "note": "CHECK [-180..180]"
        },
        "valid_from": {
          "type": "TEXT",
          "nullable": false
        },
        "valid_to": {
          "type": "TEXT",
          "nullable": true
        },
        "recorded_at": {
          "type": "TEXT",
          "nullable": false
        },
