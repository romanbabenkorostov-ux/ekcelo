        },
        "name": {
          "type": "TEXT",
          "nullable": false
        },
        "created_at": {
          "type": "TEXT",
          "nullable": false,
          "note": "ISO datetime; default datetime('now')"
        },
        "source": {
          "type": "TEXT",
          "nullable": false,
          "note": "manual|kmz|nspd|llm|exif; default 'manual'"
        },
        "confidence": {
          "type": "REAL",
          "nullable": false,
          "note": "[0..1]; default 1.0"
        }
      }
    },
    "geo_entity_contour": {
      "section": "7",
      "restorable": false,
      "primary_key": [
        "contour_id"
      ],
      "foreign_keys": [
        {
          "columns": [
            "geo_uuid"
          ],
          "references": "geo_entity(geo_uuid)",
          "on_delete": "CASCADE"
        }
      ],
      "columns": {
        "contour_id": {
          "type": "INTEGER",
          "nullable": false,
          "pk": true,
          "note": "AUTOINCREMENT"
        },
        "geo_uuid": {
          "type": "TEXT",
          "nullable": false
        },
        "geometry": {
          "type": "TEXT",
          "nullable": false,
          "note": "GeoJSON Polygon: {type:Polygon, coordinates:[...]}"
        },
        "valid_from": {
          "type": "TEXT",
          "nullable": false,
          "note": "ISO date/datetime; bitemporal valid_from"
        },
        "valid_to": {
          "type": "TEXT",
          "nullable": true,
          "note": "NULL = по сей день; CHECK valid_to > valid_from"
        },
        "recorded_at": {
          "type": "TEXT",
          "nullable": false,
          "note": "когда узнали; default datetime('now')"
        },
        "source": {
          "type": "TEXT",
          "nullable": false,
          "note": "default 'manual'"
        },
        "confidence": {
          "type": "REAL",
          "nullable": false,
          "note": "[0..1]; default 1.0"
        }
      }
    },
    "geo_entity_point": {
