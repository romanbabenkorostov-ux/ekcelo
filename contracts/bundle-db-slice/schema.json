        {
          "columns": [
            "cad_number"
          ],
          "references": "objects(cad_number)"
        }
      ],
      "columns": {
        "lot_id": {
          "type": "TEXT",
          "nullable": false,
          "pk": true
        },
        "cad_number": {
          "type": "TEXT",
          "nullable": false,
          "pk": true
        },
        "role": {
          "type": "TEXT",
          "nullable": false,
          "check_in": [
            "building",
            "land",
            "room",
            "equipment",
            "structure"
          ]
        },
        "ord": {
          "type": "INTEGER",
          "nullable": false,
          "default": "1"
        }
      }
    },
    "geo_entity": {
      "section": "7",
      "restorable": false,
      "primary_key": [
        "geo_uuid"
      ],
      "columns": {
        "geo_uuid": {
          "type": "TEXT",
          "nullable": false,
          "pk": true,
