# Ключи внешних источников данных о субъектах (ЕГРЮЛ/ЕГРИП).
# Скопируй в parser/.env и впиши свои ключи. parser/.env НЕ коммитится
# (см. .gitignore: .env / .env.*, исключение — .env.example).
#
# Используется: egrn_parser/parsers/egrul_egrip_sources.py::fetch_by_inn
# Без ключей парсинг ИНН/ОГРН возможен из PDF-выписки (offline, без сети).

# checko.ru — личный кабинет → API (https://checko.ru)
CHECKO_API_KEY=

# dadata.ru — профиль → API-ключи (https://dadata.ru/api/find-party/)
DADATA_API_KEY=
DADATA_SECRET_KEY=
